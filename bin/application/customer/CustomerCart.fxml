<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-font-size: 20px;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="application.customer.CustomerCartController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #4E342E; -fx-padding: 10;">
            <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" text="My Cart" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#goToDashboard" style="-fx-background-color: #FF8F00; -fx-text-fill: white;" text="Continue Shopping" />
            <Button onAction="#logout" style="-fx-background-color: #C62828; -fx-text-fill: white;" text="Logout" />
        </HBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

            <TableView fx:id="tblCart" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCartId" prefWidth="60" text="Cart ID" style="-fx-font-size: 20;" />
                    <TableColumn fx:id="colProduct" prefWidth="220" text="Product" style="-fx-font-size: 20;" />
                    <TableColumn fx:id="colPrice" prefWidth="120" text="Price" style="-fx-font-size: 20;" />
                    <TableColumn fx:id="colQuantity" prefWidth="100" text="Qty" style="-fx-font-size: 20;" />
                    <TableColumn fx:id="colSubtotal" prefWidth="140" text="Subtotal" style="-fx-font-size: 20;" />
                </columns>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Set Quantity:" />
                <Spinner fx:id="spnQuantity" prefWidth="80" />
                <Button onAction="#updateQuantity" style="-fx-background-color: #2E7D32; -fx-text-fill: white;" text="Update Qty" />
                <Button onAction="#removeItem" style="-fx-background-color: #C62828; -fx-text-fill: white;" text="Remove Item" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTotal" style="-fx-font-weight: bold; -fx-font-size: 22;" text="Total: $0.00" />
            </HBox>

            <Label fx:id="lblMessage" text="" />

            <HBox alignment="CENTER_RIGHT">
                <Button onAction="#proceedToCheckout" prefHeight="45" prefWidth="250"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;"
                        text="Proceed to Checkout" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
