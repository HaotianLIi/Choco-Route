<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-font-size: 20px;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="application.customer.CustomerDashboardController">

    <!-- Top: Header with navigation -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #4E342E; -fx-padding: 10;">
            <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" text="ChocoRoute - Customer Dashboard" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblWelcome" style="-fx-text-fill: white; -fx-font-size: 20;" text="Welcome!" />
            <Button onAction="#goToCart" style="-fx-background-color: #FF8F00; -fx-text-fill: white;" text="My Cart" />
            <Button onAction="#goToOrders" style="-fx-background-color: #FF8F00; -fx-text-fill: white;" text="My Orders" />
            <Button onAction="#logout" style="-fx-background-color: #C62828; -fx-text-fill: white;" text="Logout" />
        </HBox>
    </top>

    <!-- Center: Product table -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="10">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

            <TableView fx:id="tblProducts" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colName" prefWidth="180" text="Name" />
                    <TableColumn fx:id="colDescription" prefWidth="250" text="Description" />
                    <TableColumn fx:id="colPrice" prefWidth="120" text="Price ($)" />
                    <TableColumn fx:id="colStock" prefWidth="120" text="In Stock" />
                </columns>
            </TableView>

            <HBox alignment="CENTER" spacing="10">
                <Label text="Quantity:" />
                <Spinner fx:id="spnQuantity" prefWidth="80" />
                <Button onAction="#addToCart" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-size: 20;" text="Add to Cart" />
                <Label fx:id="lblMessage" style="-fx-font-size: 20;" text="" />
            </HBox>
        </VBox>
    </center>

</BorderPane>
