<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-font-size: 20px;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="application.customer.CustomerCheckoutController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #4E342E; -fx-padding: 10;">
            <Label style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" text="Checkout" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#goToCart" style="-fx-background-color: #FF8F00; -fx-text-fill: white;" text="Back to Cart" />
            <Button onAction="#logout" style="-fx-background-color: #C62828; -fx-text-fill: white;" text="Logout" />
        </HBox>
    </top>

    <center>
        <VBox spacing="15">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

            <Label style="-fx-font-weight: bold; -fx-font-size: 22;" text="Order Summary" />

            <TableView fx:id="tblSummary" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colProduct" prefWidth="220" text="Product" style="-fx-font-size: 20;" />
                    <TableColumn fx:id="colPrice" prefWidth="120" text="Price" style="-fx-font-size: 20;" />
                    <TableColumn fx:id="colQuantity" prefWidth="100" text="Qty" style="-fx-font-size: 20;" />
                    <TableColumn fx:id="colSubtotal" prefWidth="140" text="Subtotal" style="-fx-font-size: 20;" />
                </columns>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="Ship to:" />
                <ComboBox fx:id="cmbCountry" prefWidth="200" onAction="#updateShipping" />
            </HBox>

            <VBox spacing="5" alignment="CENTER_RIGHT" style="-fx-padding: 10; -fx-border-color: #ccc; -fx-border-radius: 5;">
                <Label fx:id="lblItemsTotal" style="-fx-font-size: 20;" text="Items Total: $0.00" />
                <Label fx:id="lblShipping" style="-fx-font-size: 20;" text="Shipping: $0.00" />
                <Separator />
                <Label fx:id="lblGrandTotal" style="-fx-font-weight: bold; -fx-font-size: 24;" text="Grand Total: $0.00" />
            </VBox>

            <Label fx:id="lblMessage" text="" />

            <HBox alignment="CENTER_RIGHT">
                <Button onAction="#confirmOrder" prefHeight="45" prefWidth="250"
                        style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;"
                        text="Confirm Order" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
