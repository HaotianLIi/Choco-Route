<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="application.admin.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #1B5E20; -fx-padding: 10;">
            <Label style="-fx-text-fill: white; -fx-font-size: 30; -fx-font-weight: bold;" text="ChocoRoute - Admin Dashboard" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblWelcome" style="-fx-text-fill: white; -fx-font-size: 24;" text="Admin" />
            <Button onAction="#logout" style="-fx-background-color: #C62828; -fx-text-fill: white; -fx-font-size: 24" text="Logout" />
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">
            <padding><Insets bottom="60" left="40" right="40" top="60" /></padding>

            <Label style="-fx-font-size: 24; -fx-font-weight: bold;" text="Admin Control Panel" />

            <Button onAction="#goToProducts" prefHeight="50" prefWidth="300" style="-fx-background-color: #4E342E; -fx-text-fill: white; -fx-font-size: 24;" text="Manage Inventory" />

            <Button onAction="#goToOrders" prefHeight="50" prefWidth="300" style="-fx-background-color: #4E342E; -fx-text-fill: white; -fx-font-size: 24;" text="Manage Orders" />
        </VBox>
    </center>

</BorderPane>
